# =============================================================================
# Skill Network V2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Client-side (safe to expose, scoped by Row Level Security)
# Find these in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your project's REST/Realtime endpoint
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The "anon" public key — safe to ship in client bundles (RLS protects data)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Short project reference ID (used by some Supabase CLI commands / edge functions)
VITE_SUPABASE_PROJECT_ID=your-project-ref

# -----------------------------------------------------------------------------
# Supabase — Server-side only (NEVER expose to the browser)
# Find these in: Supabase Dashboard → Project Settings → API → Service Role
# These bypass Row Level Security — only use in trusted server environments.
# -----------------------------------------------------------------------------

# Service role key — full admin access, bypasses RLS
# Only required for server-side scripts, edge functions, or admin tooling
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Repeated here for server environments that don't have access to VITE_ prefixes
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# -----------------------------------------------------------------------------
# Optional: Lovable Cloud OAuth
# Only needed if you are using Lovable's managed OAuth flow
# -----------------------------------------------------------------------------
# VITE_LOVABLE_CLIENT_ID=your-lovable-oauth-client-id

# -----------------------------------------------------------------------------
# Optional: Sentry error tracking
# Get your DSN from: https://sentry.io → Project → Settings → Client Keys
# -----------------------------------------------------------------------------
# VITE_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Optional: app version (injected by CI/CD)
# VITE_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Edge function secrets (set these in Supabase Dashboard → Edge Functions → Secrets)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=your-google-gemini-api-key
# ALLOWED_ORIGINS=https://your-production-domain.com,https://your-preview.workers.dev
